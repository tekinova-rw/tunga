# backend/.env

# Server Configuration
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=vetconnect

# JWT Secrets (for authentication)
JWT_ACCESS_SECRET=vetconnect_access_secret_key_2024
JWT_REFRESH_SECRET=vetconnect_refresh_secret_key_2024

# Frontend URL (for password reset link)
FRONTEND_URL=http://localhost:8081

# Email Configuration (for password reset - optional for testing)
# If you don't set these, the reset link will be logged to console
EMAIL_USER=
EMAIL_PASS=